{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "level": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "published": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "level",
    "slug"
  ]
}