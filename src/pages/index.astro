---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="Beranda" description="Pondok Pesantren Thibbil Qulub Assimbani — Lembaga pendidikan Islam modern yang mencetak generasi religius, cinta sholawat, berkualitas, dan santun.">
  <!-- Hero -->
  <section class="hero-padding bg-gradient-to-b from-brand-green-dark to-neutral-950 text-white">
    <div class="container-site text-center">
      <h1 class="text-display-xl font-semibold mb-6 text-balance">
        Membentuk Generasi<br />
        <span class="text-brand-gold">Berilmu, Beriman, Berkarakter</span>
      </h1>
      <p class="text-body-lg text-neutral-300 max-w-2xl mx-auto mb-10 leading-relaxed">
        Pondok Pesantren Thibbil Qulub Assimbani menggabungkan pendidikan Islam klasik dengan teknologi modern untuk mencetak generasi yang religius dan siap menghadapi masa depan.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="primary" size="lg" href="/ppdb">Daftar Sekarang</Button>
        <Button variant="outline" size="lg" href="/about">Tentang Kami</Button>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section-padding">
    <div class="container-site max-w-3xl text-center">
      <p class="text-body-sm font-semibold text-brand-green uppercase tracking-wider mb-3">Selamat Datang</p>
      <h2 class="text-display-lg font-semibold text-neutral-800 mb-6">Pendidikan Islam untuk Masa Depan</h2>
      <p class="text-body text-neutral-600 leading-relaxed">
        Thibbil Qulub Assimbani adalah lembaga pendidikan Islam yang berkomitmen mencetak generasi unggul. Berdiri di atas nilai-nilai religius, cinta sholawat, dan semangat berkualitas, kami menyediakan lingkungan belajar yang modern, islami, dan berkarakter.
      </p>
    </div>
  </section>

  <!-- Core Values -->
  <section class="section-padding bg-neutral-100">
    <div class="container-site">
      <p class="text-body-sm font-semibold text-brand-green uppercase tracking-wider text-center mb-3">Nilai Kami</p>
      <h2 class="text-display-lg font-semibold text-neutral-800 text-center mb-12">Fundamental Pendidikan</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-8 border border-neutral-200 text-center">
          <div class="w-14 h-14 rounded-full bg-brand-green-light flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          </div>
          <h3 class="text-heading-3 font-semibold text-neutral-800 mb-3">Religius</h3>
          <p class="text-body-sm text-neutral-600 leading-relaxed">Iman dan takwa sebagai fondasi setiap langkah pendidikan.</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-neutral-200 text-center">
          <div class="w-14 h-14 rounded-full bg-brand-gold-light flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          </div>
          <h3 class="text-heading-3 font-semibold text-neutral-800 mb-3">Cinta Sholawat</h3>
          <p class="text-body-sm text-neutral-600 leading-relaxed">Kecintaan kepada Nabi sebagai pembentuk akhlak mulia.</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-neutral-200 text-center">
          <div class="w-14 h-14 rounded-full bg-brand-green-light flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-heading-3 font-semibold text-neutral-800 mb-3">Berkualitas</h3>
          <p class="text-body-sm text-neutral-600 leading-relaxed">Standar mutu tinggi dalam akademik dan karakter.</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-neutral-200 text-center">
          <div class="w-14 h-14 rounded-full bg-brand-gold-light flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 10h-2m2 0a2 2 0 012 2v6a2 2 0 01-2 2H6a2 2 0 01-2-2v-6a2 2 0 012-2m2-2V8a4 4 0 118 0v2m-4 4h.02"/></svg>
          </div>
          <h3 class="text-heading-3 font-semibold text-neutral-800 mb-3">Santun</h3>
          <p class="text-body-sm text-neutral-600 leading-relaxed">Akhlak karimah dalam setiap interaksi dan perilaku.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Education Units Overview -->
  <section class="section-padding">
    <div class="container-site">
      <p class="text-body-sm font-semibold text-brand-green uppercase tracking-wider text-center mb-3">Unit Pendidikan</p>
      <h2 class="text-display-lg font-semibold text-neutral-800 text-center mb-4">Jenjang Pendidikan</h2>
      <p class="text-body text-neutral-600 text-center max-w-xl mx-auto mb-12">
        Tiga unit pendidikan dalam satu naungan pondok pesantren.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/education/pondok-pesantren" class="group bg-white rounded-xl p-8 border border-neutral-200 no-underline hover:border-brand-green transition-colors">
          <h3 class="text-heading-3 font-semibold text-neutral-800 mb-3 group-hover:text-brand-green transition-colors">Pondok Pesantren</h3>
          <p class="text-body-sm text-neutral-600 leading-relaxed mb-4">Pendidikan kepesantrenan dengan fokus pada tahfidz, kajian kitab, dan pembentukan karakter islami.</p>
          <span class="text-body-sm font-medium text-brand-green">Selengkapnya →</span>
        </a>
        <a href="/education/mts" class="group bg-white rounded-xl p-8 border border-neutral-200 no-underline hover:border-brand-green transition-colors">
          <h3 class="text-heading-3 font-semibold text-neutral-800 mb-3 group-hover:text-brand-green transition-colors">MTs Thibbil Qulub</h3>
          <p class="text-body-sm text-neutral-600 leading-relaxed mb-4">Madrasah Tsanawiyah dengan kurikulum integratif agama dan sains untuk generasi muda islami.</p>
          <span class="text-body-sm font-medium text-brand-green">Selengkapnya →</span>
        </a>
        <a href="/education/smk" class="group bg-white rounded-xl p-8 border border-neutral-200 no-underline hover:border-brand-green transition-colors">
          <h3 class="text-heading-3 font-semibold text-neutral-800 mb-3 group-hover:text-brand-green transition-colors">SMK Thibbil Qulub</h3>
          <p class="text-body-sm text-neutral-600 leading-relaxed mb-4">Sekolah Menengah Kejuruan dengan kompetensi teknologi informasi dan keterampilan abad 21.</p>
          <span class="text-body-sm font-medium text-brand-green">Selengkapnya →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Programs Overview -->
  <section class="section-padding bg-neutral-100">
    <div class="container-site">
      <p class="text-body-sm font-semibold text-brand-green uppercase tracking-wider text-center mb-3">Program Unggulan</p>
      <h2 class="text-display-lg font-semibold text-neutral-800 text-center mb-12">Program Kami</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 border border-neutral-200 flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-green-light flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <div>
            <h3 class="text-heading-3 font-semibold text-neutral-800 mb-1">Tahfidz Al-Quran</h3>
            <p class="text-body-sm text-neutral-600">Program hafalan Al-Quran dengan metode mutqin dan bimbingan intensif.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 border border-neutral-200 flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-gold-light flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <div>
            <h3 class="text-heading-3 font-semibold text-neutral-800 mb-1">Kajian Kitab Kuning</h3>
            <p class="text-body-sm text-neutral-600">Pendalaman kitab klasik sebagai warisan intelektual Islam.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 border border-neutral-200 flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-green-light flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="text-heading-3 font-semibold text-neutral-800 mb-1">Bahasa Arab</h3>
            <p class="text-body-sm text-neutral-600">Penguasaan bahasa Al-Quran untuk pemahaman ilmu agama yang lebih dalam.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 border border-neutral-200 flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-gold-light flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="text-heading-3 font-semibold text-neutral-800 mb-1">Bahasa Inggris</h3>
            <p class="text-body-sm text-neutral-600">Kemampuan global untuk menghadapi tantangan internasional.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 border border-neutral-200 flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-green-light flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <h3 class="text-heading-3 font-semibold text-neutral-800 mb-1">Teknologi Informasi</h3>
            <p class="text-body-sm text-neutral-600">Keterampilan digital dan pemrograman untuk masa depan.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 border border-neutral-200 flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-gold-light flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div>
            <h3 class="text-heading-3 font-semibold text-neutral-800 mb-1">Kepemimpinan</h3>
            <p class="text-body-sm text-neutral-600">Pembentukan jiwa pemimpin yang amanah dan bertanggung jawab.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section-padding">
    <div class="container-site">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-display-lg font-semibold text-brand-green">150+</p>
          <p class="text-body-sm text-neutral-600 mt-1">Santri Aktif</p>
        </div>
        <div>
          <p class="text-display-lg font-semibold text-brand-gold">25+</p>
          <p class="text-body-sm text-neutral-600 mt-1">Tenaga Pendidik</p>
        </div>
        <div>
          <p class="text-display-lg font-semibold text-brand-green">3</p>
          <p class="text-body-sm text-neutral-600 mt-1">Unit Pendidikan</p>
        </div>
        <div>
          <p class="text-display-lg font-semibold text-brand-gold">6</p>
          <p class="text-body-sm text-neutral-600 mt-1">Program Unggulan</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-brand-green-dark text-white text-center">
    <div class="container-site max-w-2xl">
      <h2 class="text-display-lg font-semibold mb-4">Bergabunglah Bersama Kami</h2>
      <p class="text-body text-neutral-300 mb-8 leading-relaxed">
        Daftarkan putra-putri Anda untuk menjadi bagian dari generasi penerus yang religius, cinta sholawat, berkualitas, dan santun.
      </p>
      <a
        href="/ppdb"
        class="inline-flex items-center text-body-sm font-semibold text-brand-green-dark bg-brand-gold hover:bg-brand-gold-light px-8 py-3.5 rounded-lg no-underline transition-colors"
      >
        Daftar PPDB {new Date().getFullYear()}
      </a>
    </div>
  </section>
</BaseLayout>
