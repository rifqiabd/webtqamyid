---
export interface Props {
  type?: 'text' | 'email' | 'tel' | 'search';
  placeholder?: string;
  required?: boolean;
  class?: string;
}

const { type = 'text', placeholder, required, class: className } = Astro.props;
---

<input
  {type}
  {placeholder}
  {required}
  class={`w-full h-11 px-4 text-body bg-white border border-neutral-300 rounded-lg placeholder:text-neutral-500 focus:outline-none focus:border-brand-green focus:ring-1 focus:ring-brand-green transition-colors ${className ?? ''}`}
/>
