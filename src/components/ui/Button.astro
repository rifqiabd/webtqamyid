---
export interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'link';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const { variant = 'primary', size = 'md', href, class: className } = Astro.props;

const base = 'inline-flex items-center justify-center font-medium transition-all duration-200 cursor-pointer no-underline';

const variants: Record<string, string> = {
  primary: 'bg-brand-green text-white hover:bg-brand-green-dark',
  secondary: 'bg-white text-neutral-800 border border-neutral-300 hover:border-neutral-400',
  outline: 'bg-transparent text-neutral-800 border border-neutral-300 hover:bg-neutral-100',
  ghost: 'bg-transparent text-neutral-700 hover:bg-neutral-100',
  link: 'bg-transparent text-brand-green hover:text-brand-green-dark underline-offset-2 hover:underline p-0',
};

const sizes: Record<string, string> = {
  sm: 'text-caption px-3 py-1.5 rounded-md',
  md: 'text-body-sm px-4 py-2.5 rounded-lg',
  lg: 'text-body-sm px-6 py-3 rounded-lg',
};
---

{
  href ? (
    <a href={href} class={`${base} ${variants[variant]} ${sizes[size]} ${className ?? ''}`}>
      <slot />
    </a>
  ) : (
    <button class={`${base} ${variants[variant]} ${sizes[size]} ${className ?? ''}`}>
      <slot />
    </button>
  )
}
